PORT=3000

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name

# Some buckets disallow ACLs. Leave this blank if so.
# Example (only if your bucket allows ACLs):
# AWS_S3_OBJECT_ACL=public-read
AWS_S3_OBJECT_ACL=

# Firebase Admin
FIREBASE_PROJECT_ID=your_firebase_project_id
# Recommended: service account JSON file in ./server/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_PATH=./server/serviceAccountKey.json

UPLOAD_MAX_BYTES=209715200

